<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= file.name %> — FileVault</title>
  <link rel="stylesheet" href="../public/style.css" />
</head>
<body>

  <nav>
    <a href="/" class="brand">filevault/</a>
    <div class="nav-links">
      <a href="/folders/<%= file.folderId %>" class="btn btn-ghost btn-sm">← Back to Folder</a>
      <form action="/logout" method="POST" style="margin:0;">
        <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
      </form>
    </div>
  </nav>

  <div class="container">
    <h2 class="page-title">File Details</h2>

    <div class="card">
      <div class="detail-grid">
        <span class="detail-label">Name</span>
        <span class="detail-value"><%= file.name %></span>

        <span class="detail-label">Size</span>
        <span class="detail-value"><%= (file.size / 1024).toFixed(2) %> KB</span>

        <span class="detail-label">Type</span>
        <span class="detail-value"><%= file.mimeType %></span>

        <span class="detail-label">Uploaded</span>
        <span class="detail-value"><%= new Date(file.createdAt).toLocaleString() %></span>
      </div>

      <hr class="divider" />

      <div style="display:flex; gap:0.75rem;">
        <a href="/files/<%= file.id %>/download" class="btn btn-primary">Download</a>
        <a href="/folders/<%= file.folderId %>" class="btn btn-ghost">Back to Folder</a>
      </div>
    </div>
  </div>

</body>
</html>
