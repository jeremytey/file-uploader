<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= name %> — FileVault</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <nav>
    <a href="/" class="brand">filevault/</a>
    <div class="nav-links">
      <a href="/" class="btn btn-ghost btn-sm">← My Drive</a>
      <form action="/logout" method="POST" style="margin:0;">
        <button type="submit" class="btn btn-ghost btn-sm">Log out</button>
      </form>
    </div>
  </nav>

  <div class="container">

    <% if (locals.message) { %>
      <div class="alert alert-error"><%= message %></div>
    <% } %>

    <% if (locals.link) { %>
      <div class="alert alert-success">
        Share link generated:
        <div class="share-link-box" style="margin-top:0.5rem;">
          <span><%= link %></span>
          <button class="btn btn-ghost btn-sm" onclick="navigator.clipboard.writeText('<%= link %>')">Copy</button>
        </div>
      </div>
    <% } %>

    <!-- Folder Header -->
    <div class="toolbar">
      <!-- Rename Form -->
      <form action="/folders/<%= folderId %>?_method=PATCH" method="POST" class="inline-form">
        <input type="text" name="name" value="<%= name %>" required />
        <button type="submit" class="btn btn-ghost btn-sm">Rename</button>
      </form>

      <!-- Share Form -->
      <form action="/folders/<%= folderId %>/share" method="POST" style="display:flex; gap:0.5rem; align-items:center;">
        <select name="duration">
          <option value="1d">1 day</option>
          <option value="7d">7 days</option>
          <option value="30d">30 days</option>
        </select>
        <button type="submit" class="btn btn-ghost btn-sm">Share</button>
      </form>
    </div>

    <!-- Upload File Form -->
    <div class="card" style="margin-bottom:2rem;">
      <p style="font-size:0.8rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.75rem;">Upload File</p>
      <form action="/files/upload/<%= folderId %>" method="POST" enctype="multipart/form-data"
            style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
        <input type="file" name="file" required
               style="flex:1; color:var(--text); background:var(--bg); border:1px solid var(--border);
                      border-radius:var(--radius); padding:0.55rem 0.9rem; font-family:var(--sans);" />
        <button type="submit" class="btn btn-primary">Upload</button>
      </form>
    </div>

    <!-- File List -->
    <% if (files.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📄</div>
        <p>No files in this folder yet.</p>
      </div>
    <% } else { %>
      <ul class="item-list">
        <% files.forEach(file => { %>
          <li class="item-row">
            <span class="item-icon">📄</span>
            <a href="/files/<%= file.id %>" class="item-name"><%= file.name %></a>
            <span class="item-meta"><%= (file.size / 1024).toFixed(1) %> KB</span>
            <div class="item-actions">
              <a href="/files/<%= file.id %>/download" class="btn btn-ghost btn-sm">Download</a>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>

  </div>

</body>
</html>
